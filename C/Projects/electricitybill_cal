#include <stdio.h>

int main() {
    int units;
    float billAmount;
    printf("Enter total units consumed: ");
    scanf("%d", &units);
    if (units <= 50) {
        billAmount = units * 0.50;
    } else if (units <= 150) {
        billAmount = 25 + (units - 50) * 0.75;
    } else if (units <= 250) {
        billAmount = 100 + (units - 150) * 1.20;
    } else {
        billAmount = 220 + (units - 250) * 1.50;
    }
    printf("Electricity bill: $%.2f\n", billAmount);
    return 0;
}

